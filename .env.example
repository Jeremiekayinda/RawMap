# RawMap — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs

# Django
DJANGO_SECRET_KEY=change-me-to-a-secure-random-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Africa/Kinshasa

# Base de données
# sqlite (défaut, dev local) | postgresql (production / équipe)
DB_ENGINE=sqlite

# PostgreSQL (utilisé si DB_ENGINE=postgresql)
POSTGRES_DB=rawmap
POSTGRES_USER=rawmap_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

# Django REST Framework
DRF_PAGE_SIZE=20

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_CREDENTIALS=True

# CSRF
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=False

# PostGIS / GeoDjango (optionnel — réactivation future)
# USE_GEODJANGO=True
# GDAL_LIBRARY_PATH=C:\OSGeo4W\bin\gdal312.dll
# GEOS_LIBRARY_PATH=C:\OSGeo4W\bin\geos_c.dll
